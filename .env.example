# Server
NODE_ENV=development
PORT=3000
API_KEY=your-secure-api-key-min-32-chars-long

# Multi-tenancy / DB (use real DB in production)
# DATABASE_URL=postgresql://user:pass@localhost:5432/platform

# CORS (comma-separated origins; no wildcards)
ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# Third-party integrations
WEBHOOK_SECRET=your-webhook-signing-secret
INTEGRATION_OAUTH_CLIENT_ID=
INTEGRATION_OAUTH_CLIENT_SECRET=

# Analytics / feature flags (optional)
# SEGMENT_WRITE_KEY=
# ENABLE_ANALYTICS=true
